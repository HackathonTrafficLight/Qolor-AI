{
  "manifest_version": 3,
  "name": "YouTube Video Collector",
  "version": "1.0",
  "description": "Collects video URLs and IDs from YouTube.",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["style.css"],
      "js": ["content/content.js"]
    }
  ]
}
