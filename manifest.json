{
  "manifest_version": 3,
  "name": "YouTube Video Collector",
  "version": "2.0",
  "description": "Collects and saves video IDs from YouTube to Firebase.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/content.js"],
      "css": ["style.css"]
    }
  ]
}